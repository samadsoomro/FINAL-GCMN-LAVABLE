{
    "buildCommand": "npm run build",
    "outputDirectory": "dist/public",
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.ts"
        },
        {
            "src": "/server/uploads/(.*)",
            "dest": "/api/index.ts"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "functions": {
        "api/index.ts": {
            "includeFiles": "server/**"
        }
    }
}